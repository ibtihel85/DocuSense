# DocuSense – Environment Configuration
# Copy this file to .env and adjust values as needed

# ── LLM (Ollama) ──────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# Alternatives: mistral:7b | gemma3:4b | llama3.2:3b (faster, less accurate)
OLLAMA_TIMEOUT=120                 # Seconds to wait for LLM response
OLLAMA_TEMPERATURE=0.1             # Low temp for factual accuracy

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Alternative: all-MiniLM-L6-v2 (smaller, slightly less accurate)
EMBEDDING_DEVICE=cpu               # Force CPU inference

# ── Vector Store (ChromaDB) ───────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=docusense_docs

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=10                 # Total chunks to retrieve
TOP_K_DENSE=8                      # Dense (embedding) retrieval count
TOP_K_SPARSE=8                     # Sparse (BM25) retrieval count
TOP_K_FINAL=5                      # Final chunks after fusion/reranking
USE_RERANKER=true                  # Enable MiniLM cross-encoder reranker
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512                     # Target chunk size in tokens
CHUNK_OVERLAP=64                   # Overlap between chunks in tokens
MIN_CHUNK_SIZE=50                  # Discard chunks smaller than this

# ── OCR ──────────────────────────────────────────────────────────────────────
# Windows example: TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=tesseract
TESSERACT_LANG=eng+deu             # English + German (add more as needed)
OCR_DPI=300                        # DPI for PDF→image conversion

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1                      # Keep at 1 for CPU-only systems
MAX_UPLOAD_SIZE_MB=50              # Max file size for upload

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                    # json | console
LOG_FILE=./data/logs/docusense.log

# ── Data Paths ────────────────────────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
BM25_INDEX_PATH=./data/bm25_index.pkl
CHROMA_EXPORT_PATH=./data/chroma_export

# ── Evaluation ────────────────────────────────────────────────────────────────
EVAL_OUTPUT_DIR=./data/eval_results

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_COMPLIANCE_AGENT=true
ENABLE_EXTRACTION_AGENT=true
ENABLE_RERANKING=true
DEBUG_MODE=false
